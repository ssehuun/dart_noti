DART_API_KEY=your_40_char_dart_api_key
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# 감시할 종목의 corp_code 목록 (쉼표 구분)
# dart.get_corp_list().find_by_corp_name("삼성전자", exactly=True)[0].corp_code 로 확인
WATCH_CORP_CODES=00126380,00401731

# 폴링 주기 (초, 기본 300)
POLL_INTERVAL_SECONDS=300

# 발송 이력 저장 경로 (기본 data/seen.json)
STORE_PATH=data/seen.json

# 이력 보존 기간 (일, 기본 90)
SEEN_RETENTION_DAYS=90
